rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Ustaw ten sam adres co VITE_ADMIN_EMAIL przed publikacją reguł.
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'ADMIN_EMAIL_HERE';
    }

    match /users/{userId} {
      allow create: if ownsUserDocument(userId)
        && request.resource.data.uid == userId;
      allow read, update, delete: if ownsUserDocument(userId);

      match /eventActions/{eventId} {
        allow read, delete: if ownsUserDocument(userId);
        allow create, update: if ownsUserDocument(userId)
          && request.resource.data.eventId == eventId;
      }

      match /venueActions/{venueId} {
        allow read, delete: if ownsUserDocument(userId);
        allow create, update: if ownsUserDocument(userId)
          && request.resource.data.venueId == venueId;
      }
    }

    // Te kolekcje pozostają lokalne w MVP. Reguły zabezpieczają przyszłą migrację.
    match /venues/{venueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
